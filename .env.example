OPENAI_API_KEY=sk-proj_xxx
OPENAI_MODEL=gpt-5-mini
PORT=3000
APP_BASE_URL=http://localhost:3000

# 通知は任意。Telegramなら telegram、Discord webhookなら discord、Slack incoming webhookなら slack。
NOTIFY_WEBHOOK_URL=
NOTIFY_WEBHOOK_TYPE=telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# JSTで平日8:35に朝レポート取得、12:00に再取得、9-17時は15分ごとにニュース監視。
ENABLE_SCHEDULER=true
TIMEZONE=Asia/Tokyo
MORNING_CRON=35 8 * * 1-5
NOON_CRON=0 12 * * 1-5
MONITOR_CRON=*/15 9-17 * * 1-5
