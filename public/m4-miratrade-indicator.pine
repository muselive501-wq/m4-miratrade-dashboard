//@version=5
indicator("M4 Miratrade Checker", overlay=true, max_labels_count=500, max_lines_count=500)

threshold = input.int(35, "Trade threshold", minval=0, maxval=100)
bull = input.int(50, "Bull %", minval=0, maxval=100)
bear = input.int(50, "Bear %", minval=0, maxval=100)
useManualDirection = input.bool(false, "Use manual direction")
manualDirection = input.string("Buy", "Manual direction", options=["Buy", "Sell", "None"])
showTokyoWindow = input.bool(true, "Show Tokyo check window")
showTable = input.bool(true, "Show dashboard table")

confidence = math.abs(bull - bear)
autoDirection = confidence >= threshold ? bull > bear ? "Buy" : bear > bull ? "Sell" : "None" : "None"
direction = useManualDirection ? manualDirection : autoDirection
tradeOn = direction != "None"

tokyoHour = hour(time, "Asia/Tokyo")
tokyoMinute = minute(time, "Asia/Tokyo")
isEntryTime = tokyoHour == 12 and tokyoMinute == 0
isCloseTime = tokyoHour == 17 and tokyoMinute >= 55
isTradingWindow = tokyoHour >= 12 and (tokyoHour < 18 or (tokyoHour == 17 and tokyoMinute <= 55))

bgColor = direction == "Buy" ? color.new(color.teal, 88) : direction == "Sell" ? color.new(color.red, 88) : na
bgcolor(showTokyoWindow and isTradingWindow and tradeOn ? bgColor : na, title="M4 trade window")

plotshape(isEntryTime and direction == "Buy", title="M4 Buy entry", text="M4 BUY", style=shape.labelup, location=location.belowbar, color=color.teal, textcolor=color.white, size=size.small)
plotshape(isEntryTime and direction == "Sell", title="M4 Sell entry", text="M4 SELL", style=shape.labeldown, location=location.abovebar, color=color.red, textcolor=color.white, size=size.small)
plotshape(isCloseTime and tradeOn, title="M4 close", text="M4 CLOSE", style=shape.circle, location=location.abovebar, color=color.gray, textcolor=color.white, size=size.tiny)

var table info = table.new(position.top_right, 2, 5, border_width=1)

if barstate.islast and showTable
    table.cell(info, 0, 0, "M4 Miratrade", bgcolor=color.new(color.black, 0), text_color=color.white)
    table.cell(info, 1, 0, "Checker", bgcolor=color.new(color.black, 0), text_color=color.white)
    table.cell(info, 0, 1, "Bull / Bear")
    table.cell(info, 1, 1, str.tostring(bull) + "% / " + str.tostring(bear) + "%")
    table.cell(info, 0, 2, "Confidence")
    table.cell(info, 1, 2, str.tostring(confidence) + "%")
    table.cell(info, 0, 3, "Decision")
    table.cell(info, 1, 3, tradeOn ? "Trade" : "No trade")
    table.cell(info, 0, 4, "Direction")
    table.cell(info, 1, 4, direction)

alertcondition(isEntryTime and direction == "Buy", "M4 BUY", "M4 Miratrade checker: BUY entry time")
alertcondition(isEntryTime and direction == "Sell", "M4 SELL", "M4 Miratrade checker: SELL entry time")
alertcondition(isCloseTime and tradeOn, "M4 CLOSE", "M4 Miratrade checker: close time")
